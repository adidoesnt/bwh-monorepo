---
import { Logo, Navbar, SearchBar } from ".";
import { CartIcon, DumbbellIcon, MenuIcon } from "@repo/ui/icons";

// TODO: Shift to environment variables
const SHOP_URL = "https://shop.builtwithhabit.com";
const PT_URL = "https://pt.builtwithhabit.com";
---

<header class="sticky top-0 z-50 h-[12dvh] bg-base-100 shadow-md md:h-[17dvh]">
  <div
    class="grid md:grid-cols-3 grid-cols-[1fr_auto] items-center p-4 md:p-8 md:pb-0"
  >
    <div class="hidden md:flex w-full justify-start">
      <SearchBar client:load />
    </div>
    <div class="flex w-full md:justify-center justify-start ml-2 md:ml-0">
      <a href="/"><Logo /></a>
    </div>
    <div class="flex w-full justify-end md:gap-1">
      <a
        target="_blank"
        href={SHOP_URL}
        class="md:flex hidden btn btn-ghost aspect-square p-1"
      >
        <CartIcon className="md:size-6" />
      </a>
      <button class="md:hidden flex btn btn-ghost aspect-square p-1">
        <MenuIcon className="md:size-6" />
      </button>
      <a
        target="_blank"
        href={PT_URL}
        class="md:flex hidden btn btn-ghost aspect-square p-1"
      >
        <DumbbellIcon className="md:size-6" />
      </a>
    </div>
  </div>
  <div class="md:block hidden">
    <Navbar />
  </div>
</header>
