---
export const prerender = false;

import { SiteLayout } from "../layouts";
import {
  InstagramIcon,
  LinkedInIcon,
  PinterestIcon,
  TiktokIcon,
} from "@repo/ui/icons";
import { actions, isInputError } from "astro:actions";

const result = Astro.getActionResult(actions.contact);
const error = result?.error;
const inputErrors = isInputError(error) ? error.fields : {};

const getFieldError = (field: keyof typeof inputErrors) => {
  const value = inputErrors[field];
  if (Array.isArray(value)) return value[0];
  return value;
};

const isSuccess = Boolean(result?.data?.success);
if (Astro.request.method === "POST" && isSuccess) {
  return Astro.redirect("/contact", 303);
}
---

<SiteLayout>
  <div class="grid md:grid-cols-2 p-4 md:p-8 bg-base-200">
    <!-- Info section -->
    <section class="flex flex-col gap-4 p-4 md:p-6">
      <h1 class="text-3xl font-bold font-headings">contact us</h1>

      <div class="flex flex-col gap-2 font-body text-lg md:text-xl">
        <p>we'd love to hear from you!</p>
        <p>
          whether you have any questions about our blog, personal training
          services, upcoming activewear collection, brand collaborations and
          partnerships, or just want to say hello and share any feedback, please
          feel free to reach out.
        </p>
      </div>

      <h1 class="text-3xl font-bold font-headings">let's connect on socials</h1>

      <div class="flex gap-4">
        <a
          href="https://www.instagram.com/builtwithishita/"
          target="_blank"
          rel="noopener noreferrer"
        >
          <InstagramIcon className="size-8" />
        </a>

        <a
          href="https://www.linkedin.com/company/builtwithishita/"
          target="_blank"
          rel="noopener noreferrer"
        >
          <LinkedInIcon className="size-8" />
        </a>

        <a
          href="https://www.pinterest.com/builtwithishita/"
          target="_blank"
          rel="noopener noreferrer"
        >
          <PinterestIcon className="size-8" />
        </a>

        <a
          href="https://www.tiktok.com/@builtwithishita/"
          target="_blank"
          rel="noopener noreferrer"
        >
          <TiktokIcon className="size-8" />
        </a>
      </div>
    </section>

    <!-- Form section -->
    <form
      method="POST"
      action={actions.contact}
      novalidate
      class="bg-base-100 rounded-sm shadow-md p-4 md:p-6 flex flex-col gap-4"
    >
      <div class="grid md:grid-cols-2 gap-4">
        <div class="flex flex-col gap-1">
          <label for="firstName" class="font-body text-neutral font-bold">
            first name
          </label>
          <input
            id="firstName"
            name="firstName"
            type="text"
            placeholder="john"
            required
            class="w-full border border-dark-brown/40 rounded-sm p-3 font-body text-dark-brown placeholder:text-dark-brown/60 bg-white transition-colors focus:outline-none focus:border-neutral focus:ring-1 focus:ring-neutral/40"
          />
          {
            getFieldError("firstName") ? (
              <p class="font-body text-sm text-error">
                {getFieldError("firstName")}
              </p>
            ) : null
          }
        </div>

        <div class="flex flex-col gap-1">
          <label for="lastName" class="font-body text-neutral font-bold">
            last name
          </label>
          <input
            id="lastName"
            name="lastName"
            type="text"
            placeholder="doe"
            required
            class="w-full border border-dark-brown/40 rounded-sm p-3 font-body text-dark-brown placeholder:text-dark-brown/60 bg-white transition-colors focus:outline-none focus:border-neutral focus:ring-1 focus:ring-neutral/40"
          />
          {
            getFieldError("lastName") ? (
              <p class="font-body text-sm text-error">
                {getFieldError("lastName")}
              </p>
            ) : null
          }
        </div>
      </div>

      <div class="flex flex-col gap-1">
        <label for="email" class="font-body text-neutral font-bold">email</label
        >
        <input
          id="email"
          name="email"
          type="email"
          placeholder="john.doe@example.com"
          required
          class="w-full border border-dark-brown/40 rounded-sm p-3 font-body text-dark-brown placeholder:text-dark-brown/60 bg-white transition-colors focus:outline-none focus:border-neutral focus:ring-1 focus:ring-neutral/40"
        />
        {
          getFieldError("email") ? (
            <p class="font-body text-sm text-error">{getFieldError("email")}</p>
          ) : null
        }
      </div>

      <div class="flex flex-col gap-1">
        <label for="subject" class="font-body text-neutral font-bold">
          subject
        </label>
        <input
          id="subject"
          name="subject"
          type="text"
          placeholder="type your subject here..."
          required
          class="w-full border border-dark-brown/40 rounded-sm p-3 font-body text-dark-brown placeholder:text-dark-brown/60 bg-white transition-colors focus:outline-none focus:border-neutral focus:ring-1 focus:ring-neutral/40"
        />
        {
          getFieldError("subject") ? (
            <p class="font-body text-sm text-error">
              {getFieldError("subject")}
            </p>
          ) : null
        }
      </div>

      <div class="flex flex-col gap-1">
        <label for="message" class="font-body text-neutral font-bold">
          message
        </label>
        <textarea
          id="message"
          name="message"
          placeholder="type your message here..."
          rows={10}
          required
          class="w-full border border-dark-brown/40 rounded-sm p-3 font-body text-dark-brown placeholder:text-dark-brown/60 bg-white resize-y transition-colors focus:outline-none focus:border-neutral focus:ring-1 focus:ring-neutral/40"
        ></textarea>
        {
          getFieldError("message") ? (
            <p class="font-body text-sm text-error">
              {getFieldError("message")}
            </p>
          ) : null
        }
      </div>

      <label class="inline-flex items-center gap-2">
        <input
          id="isHuman"
          name="isHuman"
          type="checkbox"
          value="true"
          required
          class="checkbox checkbox-sm rounded-sm border-dark-brown/40 bg-white focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-neutral/40"
        />
        <span class="font-body text-neutral font-bold">i am a human.</span>
      </label>
      {
        getFieldError("isHuman") ? (
          <p class="font-body text-sm text-error">{getFieldError("isHuman")}</p>
        ) : null
      }

      <button
        type="submit"
        class="w-full rounded-sm bg-neutral text-neutral-content font-headings text-xl py-2 transition-opacity duration-300 hover:opacity-80 cursor-pointer"
      >
        send
      </button>
    </form>
  </div>
</SiteLayout>
