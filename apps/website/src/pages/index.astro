---
import SiteLayout from "../layouts/siteLayout.astro";
import { LogoIcon } from "@repo/ui/icons";
---

<SiteLayout>
  <section
    id="hero-section"
    class="grid place-items-center w-full bg-[url(/landing-page-hero.png)] bg-cover bg-center"
  >
    <div class="z-30 flex h-full w-full flex-col">
      <div
        class="font-headings text-light-brown flex h-full w-full flex-col items-center justify-center px-4"
      >
        <div
          class="flex flex-col items-center justify-center gap-4 md:flex-row md:gap-0"
        >
          <LogoIcon
            className="w-20 h-20 md:w-32 md:h-32 md:mr-8 drop-shadow-lg"
            color="#262626"
          />
          <div class="space-y-2 text-center md:text-left">
            <h1
              class="text-dark-brown text-3xl font-normal tracking-wide drop-shadow-lg md:text-6xl"
            >
              sweat smarter,
            </h1>
            <h1
              class="text-dark-brown text-4xl font-bold tracking-wide drop-shadow-lg md:text-7xl"
            >
              live stronger.
            </h1>
          </div>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
