---
import SiteLayout from "../layouts/siteLayout.astro";
import { LogoIcon } from "@repo/ui/icons";
import { PillarCards } from "../components";
---

<SiteLayout>
  <!-- Hero Section -->
  <section
    id="hero-section"
    class="grid place-items-center w-full bg-[url(/landing-page-hero.png)] bg-cover bg-center h-[90dvh] md:h-[85dvh]"
  >
    <div class="z-30 flex h-full w-full flex-col">
      <div
        class="font-headings text-light-brown flex h-full w-full flex-col items-center justify-center px-4"
      >
        <div
          class="flex flex-col items-center justify-center gap-4 md:flex-row md:gap-0"
        >
          <LogoIcon
            className="w-20 h-20 md:w-32 md:h-32 md:mr-8 drop-shadow-lg"
          />
          <div class="space-y-2 text-center md:text-left">
            <h1
              class="text-dark-brown md:text-4xl text-3xl font-normal tracking-wide drop-shadow-lg"
            >
              sweat smarter,
            </h1>
            <h1
              class="text-dark-brown md:text-5xl text-4xl font-bold tracking-wide drop-shadow-lg"
            >
              live stronger.
            </h1>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Slogan Section -->
  <section
    id="slogan-section"
    class="bg-base-100 grid min-h-[50dvh] place-items-center p-4 md:p-8"
  >
    <p class="font-body text-dark-brown text-center text-lg md:text-2xl">
      at <span class="font-bold">builtwithhabit,</span><br />our
      <span class="font-bold">tailored personal training programs</span> and
      <span class="font-bold">skin-safe high-performance activewear</span><br />
      meet your body where it's at and supports where it's going.
    </p>
  </section>

  <!-- Mission Section -->
  <section
    id="mission-section"
    class="bg-base-200 grid min-h-[50dvh] place-items-center py-8 p-4 md:p-8 gap-4"
  >
    <h1
      class="font-headings text-dark-brown text-center text-3xl md:text-4xl font-bold tracking-wide"
    >
      our brand mission
    </h1>

    <div
      class="grid w-full max-w-6xl gap-4 text-left md:grid-cols-[2fr_1fr] md:gap-8"
    >
      <div
        id="mission-image"
        class="order-1 flex w-full max-w-md items-center justify-center overflow-hidden rounded-sm md:order-2 md:max-w-none"
      >
        <img
          src="/headshot.png"
          alt="Headshot of the founder"
          class="h-full w-full rounded-sm object-cover"
        />
      </div>
      <div
        id="mission-text"
        class="order-2 flex flex-col justify-center gap-4 md:order-1"
      >
        <p class="font-body text-dark-brown text-lg md:text-xl">
          <span class="italic">sweat smarter.</span>
          <span class="font-bold">live stronger.</span>
        </p>
        <p class="font-body text-dark-brown text-lg md:text-xl">
          at <span class="italic">builtwithhabit,</span> we blend
          <span class="font-bold"
            >evidence-based coaching and skin-safe activewear</span
          >
          to help you train with intention, feel strong in your body and build habits
          that last!
        </p>
        <p class="font-body text-dark-brown text-lg md:text-xl">
          <span class="italic">on the coaching side,</span> i focus on the
          <span class="font-bold"
            >fundamentals: progressive resistance training, sustainable
            programming and whole-food nutrition</span
          >
          - personalised to you.
        </p>
        <p class="font-body text-dark-brown text-lg md:text-xl">
          <span class="italic">on the activewear front,</span> we're
          <span class="font-bold">rethinking activewear from the fiber up.</span
          >
          no polyester, no plastic-based coatings, no harmful dyes and no greenwashed
          gimmicks - just
          <span class="font-bold"
            >skin-safe materials engineered for real performance.</span
          >
          from high-support bras to glute-sculpting leggings, every piece is
          <span class="font-bold"
            >designed to move with you! <span class="italic"
              >[launching soon]</span
            ></span
          >
        </p>
      </div>
    </div>
  </section>

  <!-- Pillars section -->
  <section
    id="pillars-section"
    class="text-dark-brown bg-beige flex min-h-[50dvh] flex-col place-items-center gap-4 p-4 md:gap-8 md:p-8"
  >
    <h1
      class="font-headings text-dark-brown text-center text-3xl md:text-4xl font-bold tracking-wide"
    >
      our pillars
    </h1>
    <div
      class="grid w-full max-w-6xl grid-cols-1 gap-4 md:grid-cols-3 md:gap-8"
    >
      <PillarCards />
    </div>
  </section>

  <!-- Activewear Section -->
  <section
    id="waitlist-section"
    class="relative flex h-[90dvh] w-full flex-col items-center justify-center bg-[url(/activewear-athlete.jpg)] bg-cover bg-center md:h-[85dvh]"
  >
    <div class="absolute inset-0 bg-base-100/70"></div>
    <div
      class="relative z-10 flex flex-col items-center justify-center gap-4 p-4 text-center md:gap-8 md:p-8"
    >
      <a
        href="/contact?prefillType=activewear"
        class="font-headings text-dark-brown text-xl md:text-2xl font-normal italic tracking-wide underline transition-opacity hover:opacity-80"
      >
        join our waitlist
      </a>
      <h1
        class="font-headings text-dark-brown text-3xl md:text-4xl font-bold tracking-wide"
      >
        launching soon.
      </h1>
      <div class="max-w-4xl space-y-2">
        <p class="font-body text-dark-brown text-lg md:text-xl font-medium tracking-wide">
          seamless, high-performance activewear engineered from skin-safe fibers
        </p>
        <p class="font-body text-dark-brown text-lg md:text-xl font-medium tracking-wide">
          read our blog to learn about all things lifting, low-tox living and
          entrepreneurship!
        </p>
      </div>
    </div>
  </section>
</SiteLayout>
